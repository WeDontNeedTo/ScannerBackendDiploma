  "item": [
    {
      "name": "Create Location - Generated 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Warehouse {{$randomInt}}\",\n  \"kind\": \"warehouse\",\n  \"address\": \"{{$randomStreetAddress}}\",\n  \"section\": \"A{{$randomInt}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/locations",
          "host": ["{{baseUrl}}"],
          "path": ["locations"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set(\"locationId_1\", pm.response.json().id);",
              "}"
            ]
          }
        }
      ]
