    {
      "name": "Create Category - Laptops",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"laptops\",\n  \"description\": \"Portable computers\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/item-categories",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "item-categories"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set(\"categoryId_laptops\", pm.response.json().id);",
              "}"
            ]
          }
        }
      ]
    },
