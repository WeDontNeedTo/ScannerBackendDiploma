    {
      "name": "Register seed user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{seedLogin}}\",\n  \"password\": \"{{seedPassword}}\",\n  \"fullName\": \"{{seedFullName}}\",\n  \"age\": {{seedAge}},\n  \"position\": \"{{seedPosition}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  pm.collectionVariables.set(\"token\", json.token);",
              "}"
            ]
          }
        }
      ]
    },
